{
    "compilerOptions": {
        "allowJs": true,
        "incremental": true,
        "target": "ESNext",
        "module": "NodeNext",
        "declaration": true,
        "sourceMap": true,
        "composite": true,
        "strict": true,
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    }
}
